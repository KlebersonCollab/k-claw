# AI Provider Configuration
# Options: openai, anthropic, google, openrouter, ollama
AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-3.5-sonnet

# API Keys and Base URLs
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
OPENROUTER_API_KEY=your_key_here
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LangSmith Configuration (Observability)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT="agent-harness"

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USERS="123456789,987654321" # IDs de usuários permitidos separados por vírgula. Deixe vazio para permitir todos.

# Harness Permission
HARNESS_PERMISSIONS=execute #read / write / execute
